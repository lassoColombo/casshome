ARG REGISTRY_HOST
ARG BUILD_PLATFORM
ARG BUILD_ARCH
ARG IMG_NAME
ARG REGISTRY_SCOPE
ARG ENVIRONMENT

FROM --platform=${BUILD_PLATFORM}/${BUILD_ARCH} ${REGISTRY_HOST}/${IMG_NAME}-base:latest

ARG COMPONENT_NAME
COPY ${COMPONENT_NAME}/modules /root/.config/nushell/scripts

ARG COMPONENT_HELPER
COPY ${COMPONENT_NAME}/${COMPONENT_HELPER}/.config /root/.config

ENV COMPONENT_NAME=${COMPONENT_NAME}
ENV CYBERGONCI_USERID=${CYBERGONCI_USERID}
RUN git config --global user.email "${CYBERGONCI_USERID}@git.elmec.com" && \
  git config --global user.name "${CYBERGONCI_USERID}"
