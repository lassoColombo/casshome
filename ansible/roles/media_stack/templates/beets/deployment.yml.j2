apiVersion: apps/v1
kind: Deployment
metadata:
  name: beets
  namespace: media
  labels:
    app: beets
spec:
  replicas: 1
  selector:
    matchLabels:
      app: beets
  strategy:
    type: Recreate
  template:
    metadata:
      labels:
        app: beets
    spec:
      initContainers:
        - name: init-config
          image: busybox:{{ media_stack_busybox_version }}
          command:
            - sh
            - -c
            - |
              mkdir -p /music/.beets
              chown -R 1000:1000 /music/.beets
              cp /tmp/beets-config/config.yaml /config/config.yaml
          volumeMounts:
            - name: config
              mountPath: /config
            - name: music
              mountPath: /music
            - name: beets-config
              mountPath: /tmp/beets-config
              readOnly: true
      containers:
        - name: beets
          image: lscr.io/linuxserver/beets:{{ media_stack_beets_version }}
          ports:
            - containerPort: 8337
              name: http
          env:
            - name: PUID
              value: "1000"
            - name: PGID
              value: "1000"
            - name: TZ
              value: "{{ timezone }}"
          resources:
            requests:
              cpu: 50m
              memory: 64Mi
            limits:
              cpu: 500m
              memory: 256Mi
          volumeMounts:
            - name: config
              mountPath: /config
            - name: music
              mountPath: /music
          livenessProbe:
            httpGet:
              path: /
              port: 8337
            initialDelaySeconds: 30
            periodSeconds: 30
          readinessProbe:
            httpGet:
              path: /
              port: 8337
            initialDelaySeconds: 15
            periodSeconds: 10
      volumes:
        - name: config
          emptyDir: {}
        - name: beets-config
          configMap:
            name: beets-config
        - name: music
          persistentVolumeClaim:
            claimName: media-music-pvc
