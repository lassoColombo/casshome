apiVersion: batch/v1
kind: CronJob
metadata:
  name: beets-import
  namespace: media
  labels:
    app: beets
spec:
  schedule: "0 6 * * *"
  concurrencyPolicy: Forbid
  successfulJobsHistoryLimit: 3
  failedJobsHistoryLimit: 3
  jobTemplate:
    spec:
      template:
        metadata:
          labels:
            app: beets
        spec:
          restartPolicy: OnFailure
          initContainers:
            - name: init-config
              image: busybox:{{ media_stack_busybox_version }}
              command:
                - sh
                - -c
                - |
                  mkdir -p /music/.beets
                  chown -R 1000:1000 /music/.beets
                  cp /tmp/beets-config/config.yaml /config/config.yaml
              volumeMounts:
                - name: config
                  mountPath: /config
                - name: music
                  mountPath: /music
                - name: beets-config
                  mountPath: /tmp/beets-config
                  readOnly: true
          containers:
            - name: beets
              image: lscr.io/linuxserver/beets:{{ media_stack_beets_version }}
              command:
                - /bin/bash
                - -c
                - beet import -q /music
              env:
                - name: PUID
                  value: "1000"
                - name: PGID
                  value: "1000"
                - name: TZ
                  value: "{{ timezone }}"
              resources:
                requests:
                  cpu: 100m
                  memory: 128Mi
                limits:
                  cpu: 500m
                  memory: 512Mi
              volumeMounts:
                - name: config
                  mountPath: /config
                - name: music
                  mountPath: /music
          volumes:
            - name: config
              emptyDir: {}
            - name: beets-config
              configMap:
                name: beets-config
            - name: music
              persistentVolumeClaim:
                claimName: media-music-pvc
