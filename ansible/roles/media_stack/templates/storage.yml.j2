# yaml-language-server: $schema=https://raw.githubusercontent.com/yannh/kubernetes-json-schema/master/v1.31.0/list.json
#
# hostPath PVs for the media stack (single-node cluster).
# All three apps share the `media-downloads` volume.
---
# Shared: qBittorrent writes here, Lidarr reads and imports from here
# Host path: /mnt/downloads/torrents  (container mount point: /downloads)
apiVersion: v1
kind: PersistentVolume
metadata:
  name: media-downloads-pv
spec:
  capacity:
    storage: {{ media_stack_downloads_size }}
  accessModes:
    - ReadWriteOnce
  persistentVolumeReclaimPolicy: Retain
  storageClassName: ""
  hostPath:
    path: /mnt/downloads/torrents
    type: DirectoryOrCreate
---
apiVersion: v1
kind: PersistentVolumeClaim
metadata:
  name: media-downloads-pvc
  namespace: media
spec:
  accessModes:
    - ReadWriteOnce
  resources:
    requests:
      storage: {{ media_stack_downloads_size }}
  storageClassName: ""
  volumeName: media-downloads-pv
---
# Lidarr: organised music library (Jellyfin reads /mnt/media/music via its media PV)
apiVersion: v1
kind: PersistentVolume
metadata:
  name: media-music-pv
spec:
  capacity:
    storage: {{ media_stack_music_size }}
  accessModes:
    - ReadWriteOnce
  persistentVolumeReclaimPolicy: Retain
  storageClassName: ""
  hostPath:
    path: /mnt/media/music
    type: DirectoryOrCreate
---
apiVersion: v1
kind: PersistentVolumeClaim
metadata:
  name: media-music-pvc
  namespace: media
spec:
  accessModes:
    - ReadWriteOnce
  resources:
    requests:
      storage: {{ media_stack_music_size }}
  storageClassName: ""
  volumeName: media-music-pv
---
# youtube-dl staging area: manual downloads land here before beets moves them to /music
# Host path: /mnt/downloads/youtube  (container mount point: /downloads)
apiVersion: v1
kind: PersistentVolume
metadata:
  name: youtube-dl-staging-pv
spec:
  capacity:
    storage: {{ media_stack_youtube_dl_staging_size }}
  accessModes:
    - ReadWriteOnce
  persistentVolumeReclaimPolicy: Retain
  storageClassName: ""
  hostPath:
    path: /mnt/downloads/youtube
    type: DirectoryOrCreate
---
apiVersion: v1
kind: PersistentVolumeClaim
metadata:
  name: youtube-dl-staging-pvc
  namespace: media
spec:
  accessModes:
    - ReadWriteOnce
  resources:
    requests:
      storage: {{ media_stack_youtube_dl_staging_size }}
  storageClassName: ""
  volumeName: youtube-dl-staging-pv
